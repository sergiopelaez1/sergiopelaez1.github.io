# Set seed for reproducibility
set.seed(123)
# Generate random data for the independent variable (x1)
x1 <- runif(100, min = 0, max = 100)
# Generate the dependent variable (y) with a linear relationship to x1
y <- 50 + 0.5 * x1 + rnorm(100, mean = 0, sd = 10)
# Create a data frame with x1 and y
data <- data.frame(x1 = x1, y = y)
# Fit the original linear regression model
model1 <- lm(y ~ x1, data = data)
# Print the summary of model1
summary(model1)
# Transform the independent variable
data$x2 <- 100 - data$x1
# Fit the linear regression model with the transformed variable
model2 <- lm(y ~ x2, data = data)
# Print the summary of model2
summary(model2)
